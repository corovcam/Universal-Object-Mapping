{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Neo4jQueryEntrypoint",
      "request": "launch",
      "mainClass": "uom.services.benchmarks.Neo4jQueryEntrypoint",
      "projectName": "benchmarks"
    },
    {
      "name": "[orchestrator] Python Debugger: Remote Attach",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/services/orchestrator",
          "remoteRoot": "."
        }
      ]
    }
  ]
}
