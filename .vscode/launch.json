{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "[orchestrator] Python Debugger: Remote Attach",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/services/orchestrator",
          "remoteRoot": "."
        }
      ]
    }
  ]
}
